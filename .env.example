DATABASE_URL="postgresql://postgres:postgres@localhost:5432/commercial_crowdexpanse"
SESSION_SECRET="replace-this-with-a-long-random-secret"
ADMIN_EMAIL="operator@commercial.crowdexpanse.com"
ADMIN_PASSWORD="set-a-strong-admin-password"
# Isolated on-disk folder for uploaded documents (metadata only lives in Postgres)
UPLOAD_DIR="/opt/crowdexpanse/commercial/uploads"

# --- Communications / Email (Slice 3d) ---------------------------------------
# Absolute base URL for links inside emails (no trailing slash).
APP_URL="http://localhost:3030"
# Transport: "console" (default — logs, never sends; used in dev/test/CI) or "smtp".
EMAIL_PROVIDER="console"
# Default sender identity + optional reply-to (required when EMAIL_PROVIDER=smtp).
EMAIL_FROM="CrowdExpanse <no-reply@commercial.crowdexpanse.com>"
# EMAIL_REPLY_TO="support@commercial.crowdexpanse.com"
# SMTP credentials — required only when EMAIL_PROVIDER=smtp (any relay: SES/Mailgun/Postmark/Mailhog).
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="..."
# SMTP_PASS="..."
# SMTP_SECURE="false"                        # implicit TLS; auto-true for port 465

# --- Backups (D4) ------------------------------------------------------------
# Local backup root and log (defaults shown; override only if relocating).
# BACKUP_ROOT="/opt/crowdexpanse/backups/commercial"
# BACKUP_LOG="/home/deploy/.crowdexpanse-commercial-backup.log"
# BACKUP_MAX_AGE_HOURS="26"                 # freshness gate for `backup.sh check`
# Isolated restore-test database (created once: sudo -u postgres createdb -O commercial_app commercial_restore_verify)
# RESTORE_VERIFY_DB="commercial_restore_verify"
# Client-side encryption passphrase file (chmod 600, gitignored). KEEP A COPY OFF-HOST
# or you cannot decrypt R2 backups after a host loss.
# BACKUP_PASSPHRASE_FILE="/opt/crowdexpanse/commercial/.backup-passphrase"
# Off-site mirror — dedicated Cloudflare R2 bucket for CrowdExpanse Commercial.
# R2_ACCOUNT_ID="your-cloudflare-account-id"
# R2_BUCKET="crowdexpanse-commercial-backups"
# R2_ACCESS_KEY_ID="..."
# R2_SECRET_ACCESS_KEY="..."
# R2_PREFIX="commercial/"
