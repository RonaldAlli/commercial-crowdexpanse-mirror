{
  "name": "commercial-crowdexpanse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:isolated": "NEXT_DIST_DIR=.next-isolated next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/e2e-all.mjs",
    "test:ci": "npm run typecheck && npm run test",
