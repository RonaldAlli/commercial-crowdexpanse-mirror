{
  "name": "commercial-crowdexpanse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "predeploy:check": "node scripts/predeploy-check.mjs",
    "prebuild": "node scripts/predeploy-check.mjs",
    "build": "next build",
    "prebuild:isolated": "NEXT_DIST_DIR=.next-isolated node scripts/predeploy-check.mjs",
    "build:isolated": "NEXT_DIST_DIR=.next-isolated next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "node --env-file-if-exists=.env.test scripts/e2e-all.mjs",
    "test:unit": "node scripts/run-unit-tests.mjs",
    "test:ci": "npm run typecheck && npm run test:unit && npm run test",
    "perf:seed": "node --env-file-if-exists=.env.test --import tsx scripts/seed-perf.mjs",
    "perf:measure": "node --env-file-if-exists=.env.test --import tsx scripts/perf-measure.mjs",
    "perf:explain": "node --env-file-if-exists=.env.test --import tsx scripts/perf-explain.mjs",
    "test:db:setup": "node scripts/test-db.mjs setup",
    "test:db:reset": "node scripts/test-db.mjs reset",
    "test:db:sweep": "node scripts/test-db.mjs sweep",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "import:dealautomator-leads": "tsx scripts/import-dealautomator-commercial-leads.ts",
    "playwright:install": "playwright install chromium",
    "test:visual": "npm run build:isolated && playwright test",
    "test:visual:closing": "playwright test tests/visual/closing-center.behavior.spec.ts",
    "test:visual:screens": "playwright test tests/visual/closing-center.screens.spec.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "14.2.20",
    "nodemailer": "^6.10.1",
    "react": "^18",
    "react-dom": "^18",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.20",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
