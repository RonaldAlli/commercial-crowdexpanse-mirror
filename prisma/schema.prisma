generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetType {
  MULTIFAMILY
  SELF_STORAGE
  RV_PARK
  MOBILE_HOME_PARK
  RETAIL
  OFFICE
  INDUSTRIAL
  HOSPITALITY
  MIXED_USE
  LAND
}

enum OpportunityStage {
  LEAD
  SELLER_CONTACTED
  INTERESTED_SELLER
  FINANCIALS_REQUESTED
  T12_RECEIVED
  RENT_ROLL_RECEIVED
  UNDERWRITING
  OFFER_READY
  LOI_SENT
  UNDER_CONTRACT
  BUYER_MATCHED
  CLOSING
  PAID
}

enum TaskStatus {
  BACKLOG
  IN_PROGRESS
  BLOCKED
  COMPLETE
}

enum DocumentType {
  T12
  RENT_ROLL
  OFFER_MEMO
  LOI
  CONTRACT
  DUE_DILIGENCE
  PHOTO
  OTHER
}

enum MatchStatus {
  NEW
  REVIEWING
  SENT
  DECLINED
  CONFIRMED
}

enum UserRole {
  ADMIN
  ACQUISITIONS
  ANALYST
  DISPOSITIONS
}

// Account lifecycle. Only ACTIVE and DEACTIVATED are used in 1.1; SUSPENDED is
// reserved so a future temporary-suspension feature needs no enum migration.
enum UserLifecycleState {
  ACTIVE
  DEACTIVATED
  SUSPENDED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

// Commercial Intelligence (v1.2) — Owner domain. See Volume 12.
enum OwnerEntityType {
  INDIVIDUAL
  LLC
  TRUST
  CORPORATION
  PARTNERSHIP
  REIT
  GOVERNMENT
  OTHER
  UNKNOWN
}

enum OwnerStatus {
  ACTIVE
  MERGED // set on the loser of a merge (Commit 1a-2)
  ARCHIVED
}

enum OwnerMergeStatus {
  ACTIVE
  REVERSED
}

// Why two owners were merged — a typed audit dimension (Commit 1a-2).
enum OwnerMergeReason {
  DUPLICATE_IMPORT
  MANUAL_DUPLICATE
  PROVIDER_RECONCILIATION
  ALIAS_CONSOLIDATION
  OTHER
}

// Provenance ledger (Commit 1b-1). Precedence order is USER_ENTERED > LICENSED >
// PUBLIC > CALCULATION > AI_DERIVED (a tiebreak; see Volume 12 §5). AI_DERIVED is
// reserved for 2.0 and unused in 1.2.
enum SourceCategory {
  USER_ENTERED
  LICENSED
  PUBLIC
  CALCULATION
  AI_DERIVED
}

enum SignalState {
  ACCEPTED
  SUPERSEDED
}

// A human decision about whether two owners are the same identity (Commit 1d-2b).
// Decision-support only — CONFIRMED feeds the 1d-3 merge queue; it never merges.
enum OwnerMatchStatus {
  CONFIRMED
  DISMISSED
}

// Lifecycle of a single refresh run (v1.2, Commit 1c). A refresh is created
// RUNNING, then reaches exactly one terminal state: SUCCEEDED (new signals),
// NOOP (ran cleanly, every value already current), or FAILED (an exception
// during the ledger transaction — rolled back). PENDING is reserved for the
// scheduled engine (Slice 6), where a job may be queued before it starts.
enum RefreshJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  NOOP
}

// Which canonical entity a signal is about (extensible: PROPERTY, MARKET later).
enum IntelligenceEntityType {
  OWNER
}

model User {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  email          String        @unique
  hashedPassword String
  role           UserRole      @default(ACQUISITIONS)
  lifecycleState UserLifecycleState @default(ACTIVE)
  deactivatedAt  DateTime?
  deactivatedById String? // audit-only plain column (no FK), mirrors Invitation.invitedById
  // Session epoch: any signed cookie whose issuedAt predates this is rejected.
  // Set to now() on deactivation to invalidate all existing sessions at once.
  sessionsValidAfter DateTime?
  // Cursor for the notification bell: org activity newer than this (and not by
  // this user) is "unread". Null means unread-since-account-creation.
  lastNotificationsReadAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks          Task[]
  notes          Note[]
  documents      Document[]
  activities     ActivityLog[]

  @@index([organizationId])
  @@index([organizationId, lifecycleState])
  @@map("users")
}

model Organization {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  users         User[]
  sellers       Seller[]
  buyers        Buyer[]
  properties    Property[]
  opportunities Opportunity[]
  analyses      DealAnalysis[]
  tasks         Task[]
  notes         Note[]
  documents     Document[]
  matches       BuyerMatch[]
  invitations   Invitation[]
  activities    ActivityLog[]
  settings      OrganizationSettings?
  emailMessages EmailMessage[]
  owners        Owner[]
  ownerMerges   OwnerMergeRecord[]
  observations  Observation[]
  signals       IntelligenceSignal[]
  refreshJobs   RefreshJob[]
  matchDecisions OwnerMatchDecision[]

  @@map("organizations")
}

// ── Provenance ledger (v1.2, Commit 1b-1) ────────────────────────────────────
// The raw-capture layer: every inbound datum enters here FIRST, immutably.
// Observations that are rejected still persist (they simply never yield a
// Signal). Append-only — never edited or deleted. See Volume 12 §3.
model Observation {
  id                   String                 @id @default(cuid())
  organizationId       String
  entityType           IntelligenceEntityType
  entityId             String
  fieldKey             String
  valueType            String
  valueRaw             String
  valueNormalized      String?
  sourceCategory       SourceCategory
  sourceId             String
  licenseRef           String?
  asOf                 DateTime
  retrievedAt          DateTime               @default(now())
  confidence           Float                  @default(1)
  method               String
  // Which adapter (and its logic version) produced this observation, when it came
  // from a SourceAdapter (Commit 1c). Null for direct user writes, which have no
  // adapter. Lets us trace a datum to the exact adapter logic that emitted it.
  adapterVersion       Int?
  schemaVersion        Int                    @default(1)
  normalizationVersion Int                    @default(1)
  createdAt            DateTime               @default(now())
  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  signal               IntelligenceSignal?

  @@index([organizationId])
  @@index([entityType, entityId, fieldKey])
  @@map("observations")
}

// Accepted intelligence: an Observation promoted into the canonical ledger.
// IMMUTABLE — a correction is a NEW signal that SUPERSEDES the prior (never an
// edit/delete). Multiple ACCEPTED signals may coexist per field (one per source
// lineage); the projection winner is chosen by precedence in 1b-2.
model IntelligenceSignal {
  id                   String                 @id @default(cuid())
  organizationId       String
  entityType           IntelligenceEntityType
  entityId             String
  fieldKey             String
  valueType            String
  valueRaw             String
  valueNormalized      String?
  sourceCategory       SourceCategory
  sourceId             String
  licenseRef           String?
  asOf                 DateTime
  retrievedAt          DateTime               @default(now())
  confidence           Float                  @default(1)
  method               String
  state                SignalState            @default(ACCEPTED)
  isOverride           Boolean                @default(false)
  observationId        String                 @unique
  supersededById       String?
  // Carried from the originating observation (Commit 1c) — null for direct writes.
  adapterVersion       Int?
  schemaVersion        Int                    @default(1)
  normalizationVersion Int                    @default(1)
  projectionVersion    Int                    @default(1)
  createdAt            DateTime               @default(now())
  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  observation          Observation            @relation(fields: [observationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([entityType, entityId, fieldKey, state])
  @@index([supersededById])
  @@map("intelligence_signals")
}

// ── Refresh (v1.2, Commit 1c) ────────────────────────────────────────────────
// One durable record per refresh run — the SOLE audit surface for ingestion (no
// separate event stream). A RefreshJob captures who ran it, which adapter, the
// target, the counts, timing, and the outcome. It is also the idempotency
// anchor: (organizationId, sourceKey, requestKey) is unique, so re-submitting an
// identical run returns the existing job instead of applying it twice. Refresh is
// OBSERVATIONAL — it only creates Observations/Signals and triggers Projection;
// it never creates/merges/splits Owners and never deletes (Volume 12).
model RefreshJob {
  id                   String                 @id @default(cuid())
  organizationId       String
  sourceKey            String
  status               RefreshJobStatus       @default(RUNNING)
  requestKey           String // client-supplied or server content-hash (idempotency)
  targetEntityType     IntelligenceEntityType
  targetEntityId       String
  observationsRecorded Int                    @default(0)
  signalsAccepted      Int                    @default(0)
  signalsSuperseded    Int                    @default(0)
  affectedEntityIds    String[] // entities whose projection was recomputed
  actorUserId          String?
  error                String?
  startedAt            DateTime?
  finishedAt           DateTime?
  createdAt            DateTime               @default(now())
  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, sourceKey, requestKey])
  @@index([organizationId, status])
  @@map("refresh_jobs")
}

// ── Candidate Review (v1.2, Commit 1d-2b) ────────────────────────────────────
// A human's decision about a *possible* owner-duplicate pair. Decision-support
// ONLY: it records judgement, never structural identity change. The pair is
// stored in a canonical unordered form (ownerIdA < ownerIdB) so a decision is
// order-independent; owner ids are scalars, not FKs, so a later merge/tombstone
// of one side never cascade-deletes decision history. `signalFingerprint` snap-
// shots the pair's identity state (matchKey + normalized aliases) so a DISMISSED
// pair re-surfaces only on a material identity change (or explicit ADMIN reopen).
model OwnerMatchDecision {
  id                String           @id @default(cuid())
  organizationId    String
  ownerIdA          String // canonical: lexicographically smaller owner id
  ownerIdB          String // larger owner id
  status            OwnerMatchStatus
  reason            String? // match reason at decision time (audit): exact-match-key | alias-match
  signalFingerprint String // identity-state fingerprint → material-change detection
  note              String?
  decidedByUserId   String?
  decidedAt         DateTime         @default(now())
  reopenedByUserId  String? // set on explicit ADMIN reopen
  reopenedAt        DateTime? // when set, the decision is inactive (pair pending again)
  // Merge resolution (Commit 1d-3b). A CONFIRMED, active, unresolved decision is
  // "awaiting merge"; a merge CONSUMES it, stamping these. The status stays
  // CONFIRMED (there is no MERGED status) — resolution is modeled here. Unmerge
  // CLEARS these three, returning the still-CONFIRMED pair to the merge queue.
  // mergeRecordId is @unique so one merge record can resolve at most one decision.
  resolvedAt        DateTime? // set when a merge consumed this decision
  resolvedByUserId  String?
  mergeRecordId     String?          @unique // the OwnerMergeRecord produced (scalar; no FK — history-safe)
  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, ownerIdA, ownerIdB])
  @@index([organizationId, status])
  @@map("owner_match_decisions")
}

// ── Commercial Intelligence (v1.2, Slice 1 / Commit 1a) ──────────────────────
// Owner: the durable, canonical title-holding party (Volume 12 §2). Distinct
// from Seller (the transaction counterparty). In 1a, displayName/entityType are
// written directly; in 1b they become projections driven from the signal ledger.
model Owner {
  id             String                    @id @default(cuid())
  organizationId String
  displayName    String
  entityType     OwnerEntityType           @default(UNKNOWN)
  status         OwnerStatus               @default(ACTIVE)
  matchKey       String // normalized identity key; NOT unique (owners may share a normalized name)
  mergedIntoId   String? // set on a MERGED loser → its surviving winner (Commit 1a-2)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mergedInto     Owner?                    @relation("OwnerMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom     Owner[]                   @relation("OwnerMerge")
  aliases        OwnerAlias[]
  externalIds    OwnerExternalIdentifier[]
  sellers        Seller[]
  properties     Property[]

  @@index([organizationId])
  @@index([status])
  @@index([matchKey])
  @@index([mergedIntoId])
  @@map("owners")
}

// Reversible, audited record of an owner merge (Commit 1a-2). Structural only —
// it captures the graph changes needed to unmerge exactly (repointed links +
// merge-derived aliases), never business data (Volume 12 "merge is structural").
// Scalar-list columns hold the reversal payload; the record is append-only
// (status flips ACTIVE → REVERSED on unmerge, never deleted).
model OwnerMergeRecord {
  id               String           @id @default(cuid())
  organizationId   String
  winnerId         String
  loserId          String
  reason           OwnerMergeReason
  note             String?
  status           OwnerMergeStatus @default(ACTIVE)
  movedSellerIds   String[]
  movedPropertyIds String[]
  addedAliasIds    String[]
  mergedByUserId   String?
  mergedAt         DateTime         @default(now())
  reversedByUserId String?
  reversedAt       DateTime?
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([winnerId])
  @@index([loserId])
  @@index([status])
  @@map("owner_merge_records")
}

// Alternate/normalized names used to PROPOSE candidate matches (never to link
// automatically — Volume 12 S1-4). sourceCategory is a lightweight attribution
// in 1a; the full provenance-ledger link arrives in 1b.
model OwnerAlias {
  id              String   @id @default(cuid())
  ownerId         String
  value           String
  normalizedValue String
  sourceCategory  String
  createdAt       DateTime @default(now())
  owner           Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([normalizedValue])
  @@map("owner_aliases")
}

// The authoritative identity crosswalk (Volume 12 §7, S1-4). IMMUTABLE: rows are
// never edited, reassigned, or deleted — a changed mapping is a NEW row. Empty
// until a provider adapter exists, but the mechanism ships now.
model OwnerExternalIdentifier {
  id             String    @id @default(cuid())
  organizationId String
  ownerId        String
  provider       String
  externalId     String
  asOf           DateTime?
  createdAt      DateTime  @default(now())
  owner          Owner     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider, externalId])
  @@index([ownerId])
  @@map("owner_external_identifiers")
}

// Org-wide defaults, one row per organization. The single home for all
// organization configuration — accessed only through lib/org-settings.
model OrganizationSettings {
  id                String       @id @default(cuid())
  organizationId    String       @unique
  inviteExpiryDays  Int          @default(7)
  defaultInviteRole UserRole     @default(ACQUISITIONS)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

// Outbound email ledger (the "outbox"). One row per send attempt-target, written
// by lib/email/message-service BEFORE the transport is invoked, then advanced to
// SENT/FAILED. Deliberately stores METADATA ONLY — never the rendered html/text,
// invitation/reset links, tokens, or secrets (same philosophy as invitation
// token hashes). `templateVersion` gives reproducibility without retaining the
// body: support can reconstruct "what would have been sent" from template + data
// context. PENDING/FAILED rows with attempts < maxAttempts are the drain target.
model EmailMessage {
  id                String        @id @default(cuid())
  organizationId    String?       // nullable: some system emails aren't org-scoped
  toEmail           String
  template          String        // MessageKind vocabulary (open, like ActivityLog.eventType)
  templateVersion   Int           @default(1)
  subject           String        // metadata only — never the body
  status            EmailStatus   @default(PENDING)
  attempts          Int           @default(0)
  maxAttempts       Int           @default(3)
  providerMessageId String?
  error             String?
  correlationId     String?       // ties to the triggering entity (invitationId, …)
  lastAttemptAt     DateTime?
  sentAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([organizationId])
  @@map("email_messages")
}

model Seller {
  id             String        @id @default(cuid())
  organizationId String
  ownerId        String? // v1.2: the canonical Owner this deal contact represents (nullable, additive)
  name           String
  company        String?
  email          String?
  phone          String?
  motivation     String?
  city           String?
  state          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner          Owner?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  properties     Property[]
  opportunities  Opportunity[]
  notes          Note[]
  documents      Document[]
  activities     ActivityLog[]

  @@index([organizationId])
  @@index([ownerId])
  @@map("sellers")
}

model Buyer {
  id                 String        @id @default(cuid())
  organizationId     String
  name               String
  company            String?
  email              String?
  phone              String?
  targetAssetTypes   AssetType[]
  targetStates       String[]
  minimumPurchaseUsd Int?
  maximumPurchaseUsd Int?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  organization       Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  matches            BuyerMatch[]
  notes              Note[]
  documents          Document[]
  activities         ActivityLog[]

  @@index([organizationId])
  @@map("buyers")
}

model Property {
  id             String        @id @default(cuid())
  organizationId String
  sellerId       String?
  ownerId        String? // v1.2: the canonical Owner that holds title (nullable, additive)
  name           String
  assetType      AssetType
  addressLine1   String
  city           String
  state          String
  postalCode     String?
  county         String?
  unitCount      Int?
  squareFeet     Int?
  acreage        Float?
  yearBuilt      Int?
  occupancyRate  Float?
  askingPriceUsd Int?
  estimatedValueUsd Int?
  noiAnnualUsd   Int?
  capRate        Float?
  status         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  seller         Seller?       @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  owner          Owner?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  opportunities  Opportunity[]
  analyses       DealAnalysis[]
  documents      Document[]
  notes          Note[]
  activities     ActivityLog[]

  @@index([organizationId])
  @@index([sellerId])
  @@index([ownerId])
  @@map("properties")
}

model Opportunity {
  id               String           @id @default(cuid())
  organizationId   String
  propertyId       String
  sellerId         String?
  title            String
  stage            OpportunityStage @default(LEAD)
  source           String?
  priority         String?
  targetCloseDate  DateTime?
  contractValueUsd Int?
  assignmentFeeUsd Int?
  summary          String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property         Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  seller           Seller?          @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  analysis         DealAnalysis?
  tasks            Task[]
  notes            Note[]
  documents        Document[]
  buyerMatches     BuyerMatch[]
  activities       ActivityLog[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([sellerId])
  @@map("opportunities")
}

model DealAnalysis {
  id                   String        @id @default(cuid())
  organizationId       String
  propertyId           String
  opportunityId        String        @unique
  purchasePriceUsd     Int
  renovationBudgetUsd  Int?
  closingCostsUsd      Int?
  grossIncomeAnnualUsd Int?
  operatingExpensesUsd Int?
  loanAmountUsd        Int?
  interestRatePct      Float?
  amortizationYears    Int?
  noiAnnualUsd         Int?
  capRate              Float?
  dscr                 Float?
  debtYield            Float?
  pricePerUnitUsd      Float?
  analystSummary       String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  organization         Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property             Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  opportunity          Opportunity   @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([propertyId])
  @@map("deal_analysis")
}

model Task {
  id             String        @id @default(cuid())
  organizationId String
  opportunityId  String?
  ownerId        String?
  title          String
  description    String?
  status         TaskStatus    @default(BACKLOG)
  dueDate        DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity    Opportunity?  @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  owner          User?         @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([opportunityId])
  @@index([ownerId])
  @@map("tasks")
}

model Note {
  id             String        @id @default(cuid())
  organizationId String
  opportunityId  String?
  propertyId     String?
  sellerId       String?
  buyerId        String?
  authorId       String?
  body           String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity    Opportunity?  @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  property       Property?     @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  seller         Seller?       @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  buyer          Buyer?        @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  author         User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("notes")
}

model Document {
  id             String        @id @default(cuid())
  organizationId String
  opportunityId  String?
  propertyId     String?
  sellerId       String?
  buyerId        String?
  uploaderId     String?
  title          String
  documentType   DocumentType
  storageKey     String
  originalFilename String?
  mimeType       String?
  fileSizeBytes  Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity    Opportunity?  @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  property       Property?     @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  seller         Seller?       @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  buyer          Buyer?        @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  uploader       User?         @relation(fields: [uploaderId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("documents")
}

model BuyerMatch {
  id             String        @id @default(cuid())
  organizationId String
  opportunityId  String
  buyerId        String
  status         MatchStatus   @default(NEW)
  score          Int?
  thesis         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity    Opportunity   @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  buyer          Buyer         @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, buyerId])
  @@index([organizationId])
  @@index([buyerId])
  @@map("buyer_matches")
}

model Invitation {
  id             String           @id @default(cuid())
  organizationId String
  email          String           // normalized lowercase
  role           UserRole
  tokenHash      String           @unique // HMAC of the raw token; raw is never stored
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  invitedById    String? // audit-only plain column (no FK)
  acceptedUserId String? // audit-only plain column (no FK)
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitations")
}

model ActivityLog {
  id             String        @id @default(cuid())
  organizationId String
  opportunityId  String?
  propertyId     String?
  sellerId       String?
  buyerId        String?
  actorId        String?
  eventType      String
  eventLabel     String
  eventBody      String?
  createdAt      DateTime      @default(now())
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity    Opportunity?  @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  property       Property?     @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  seller         Seller?       @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  buyer          Buyer?        @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  actor          User?         @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("activity_log")
}
