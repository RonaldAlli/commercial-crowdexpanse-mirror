generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetType {
  MULTIFAMILY
  SELF_STORAGE
  RV_PARK
  MOBILE_HOME_PARK
  RETAIL
  OFFICE
  INDUSTRIAL
  HOSPITALITY
  MIXED_USE
  LAND
}

enum OpportunityStage {
  LEAD
  SELLER_CONTACTED
  INTERESTED_SELLER
  FINANCIALS_REQUESTED
  T12_RECEIVED
  RENT_ROLL_RECEIVED
  UNDERWRITING
  OFFER_READY
  LOI_SENT
  UNDER_CONTRACT
  BUYER_MATCHED
  CLOSING
  PAID
}

enum TaskStatus {
  BACKLOG
  IN_PROGRESS
  BLOCKED
  COMPLETE
}

enum DocumentType {
  T12
  RENT_ROLL
  OFFER_MEMO
  LOI
  CONTRACT
  DUE_DILIGENCE
  PHOTO
  // Generated wholesale assignment agreement (v1.4 Slice 4, AS-E). Inherits the
  // Offer-Memo generated-document framework; anchored on the Opportunity, not a scenario.
  ASSIGNMENT_AGREEMENT
  OTHER
}

// How a Document came to exist (v1.3, offer-memo generation). UPLOADED = a human
// uploaded file (the only origin before this slice). GENERATED = produced by the
// app from settled underwriting data (an offer memo). The discriminator is explicit
// so a generated artifact is never mistaken for an upload — see the Offer-Memo
// Architecture Lock (OM-G).
enum DocumentOrigin {
  UPLOADED
  GENERATED
}

// Closing Center (v1.4). A closing checklist item's category — Due Diligence ships
// first; later slices add the others. See the Closing Center Architecture Lock (CC-A).
enum ChecklistItemCategory {
  DUE_DILIGENCE
  ESCROW
  FINANCING
  ASSIGNMENT
  LEGAL
  OTHER
}

// Item lifecycle (CC-B). A REQUIRED item satisfies the PAID gate when COMPLETE or
// WAIVED; NOT_APPLICABLE is excluded from the gate.
enum ChecklistItemStatus {
  PENDING
  COMPLETE
  WAIVED
  NOT_APPLICABLE
}

// How an item is satisfied (CC-G) — declared as data, never hardcoded logic.
enum CompletionEvidenceType {
  NONE
  DOCUMENT
  TASK
  MANUAL
}

// Closing Center Slice 2 — Escrow (EC-B). The deposit lifecycle: NOT_OPENED → OPENED →
// DEPOSITED → one terminal of RELEASED / REFUNDED / FORFEITED. Transitions are validated
// by the pure guard in lib/escrow.ts.
enum EscrowStatus {
  NOT_OPENED
  OPENED
  DEPOSITED
  RELEASED
  REFUNDED
  FORFEITED
}

// The terminal financial outcomes captured as immutable, append-only EscrowEvent snapshots
// (EC-I/EC-11). Only terminal transitions are historical facts worth freezing.
enum EscrowEventType {
  RELEASED
  REFUNDED
  FORFEITED
}

// Closing Center Slice 3 — Financing (FC-B). Operational tracking of the buyer's/assignee's
// financing process: NOT_STARTED → APPLIED → COMMITTED → CLEARED → FUNDED, with terminal
// off-ramps DENIED / WITHDRAWN. This is NOT the deterministic underwriting FinancingCase —
// it never owns loan economics (FC-0/FC-3). Transitions validated by the pure guard in
// lib/financing.ts.
enum FinancingStatus {
  NOT_STARTED
  APPLIED
  COMMITTED
  CLEARED
  FUNDED
  DENIED
  WITHDRAWN
}

enum MatchStatus {
  NEW
  REVIEWING
  SENT
  DECLINED
  CONFIRMED
}

enum ContactOutreachStatus {
  NEW
  ATTEMPTING
  CONTACTED
  RESPONDED
  QUALIFIED
  DEAD
  DO_NOT_CONTACT
}

enum ContactMethod {
  CALL
  TEXT
  EMAIL
  MAIL
}

enum ContactTouchType {
  CALL
  TEXT
  EMAIL
  MAIL
  NOTE
}

enum OpportunityDiligenceStatus {
  NOT_REQUESTED
  REQUESTED
  RECEIVED
  REVIEWED
  MISSING
  NOT_APPLICABLE
}

enum UserRole {
  ADMIN
  ACQUISITIONS
  ANALYST
  DISPOSITIONS
}

// Account lifecycle. Only ACTIVE and DEACTIVATED are used in 1.1; SUSPENDED is
// reserved so a future temporary-suspension feature needs no enum migration.
enum UserLifecycleState {
  ACTIVE
  DEACTIVATED
  SUSPENDED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

// Commercial Intelligence (v1.2) — Owner domain. See Volume 12.
enum OwnerEntityType {
  INDIVIDUAL
  LLC
  TRUST
  CORPORATION
  PARTNERSHIP
  REIT
  GOVERNMENT
  OTHER
  UNKNOWN
}

enum OwnerStatus {
  ACTIVE
  MERGED // set on the loser of a merge (Commit 1a-2)
  ARCHIVED
}

enum OwnerMergeStatus {
  ACTIVE
  REVERSED
}

// Why two owners were merged — a typed audit dimension (Commit 1a-2).
enum OwnerMergeReason {
  DUPLICATE_IMPORT
  MANUAL_DUPLICATE
  PROVIDER_RECONCILIATION
  ALIAS_CONSOLIDATION
  OTHER
}

// Provenance ledger (Commit 1b-1). Precedence order is USER_ENTERED > LICENSED >
// PUBLIC > CALCULATION > AI_DERIVED (a tiebreak; see Volume 12 §5). AI_DERIVED is
// reserved for 2.0 and unused in 1.2.
enum SourceCategory {
  USER_ENTERED
  LICENSED
  PUBLIC
  CALCULATION
  AI_DERIVED
}

enum SignalState {
  ACCEPTED
  SUPERSEDED
}

// A human decision about whether two owners are the same identity (Commit 1d-2b).
// Decision-support only — CONFIRMED feeds the 1d-3 merge queue; it never merges.
enum OwnerMatchStatus {
  CONFIRMED
  DISMISSED
}

// Lifecycle of a single refresh run (v1.2, Commit 1c). A refresh is created
// RUNNING, then reaches exactly one terminal state: SUCCEEDED (new signals),
// NOOP (ran cleanly, every value already current), or FAILED (an exception
// during the ledger transaction — rolled back). PENDING is reserved for the
// scheduled engine (Slice 6), where a job may be queued before it starts.
enum RefreshJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  NOOP
}

// Which canonical entity a signal is about (extensible: MARKET later).
enum IntelligenceEntityType {
  OWNER
  PROPERTY
}

model User {
  id                      String             @id @default(cuid())
  organizationId          String
  name                    String
  email                   String             @unique
  hashedPassword          String
  role                    UserRole           @default(ACQUISITIONS)
  lifecycleState          UserLifecycleState @default(ACTIVE)
  deactivatedAt           DateTime?
  deactivatedById         String? // audit-only plain column (no FK), mirrors Invitation.invitedById
  // Session epoch: any signed cookie whose issuedAt predates this is rejected.
  // Set to now() on deactivation to invalidate all existing sessions at once.
  sessionsValidAfter      DateTime?
  // Cursor for the notification bell: org activity newer than this (and not by
  // this user) is "unread". Null means unread-since-account-creation.
  lastNotificationsReadAt DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  organization            Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks                   Task[]
  notes                   Note[]
  documents               Document[]
  activities              ActivityLog[]
  assignedOwnerContacts   OwnerContact[]     @relation("OwnerContactAssignee")
  assignedSellers         Seller[]           @relation("SellerAssignee")
  assignedBuyers          Buyer[]            @relation("BuyerAssignee")
  contactTouches          ContactTouch[]     @relation("ContactTouchActor")

  @@index([organizationId])
  @@index([organizationId, lifecycleState])
  @@map("users")
}

model Organization {
  id                     String                     @id @default(cuid())
  name                   String
  slug                   String                     @unique
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  users                  User[]
  sellers                Seller[]
  buyers                 Buyer[]
  properties             Property[]
  opportunities          Opportunity[]
  analyses               DealAnalysis[]
  tasks                  Task[]
  notes                  Note[]
  documents              Document[]
  matches                BuyerMatch[]
  invitations            Invitation[]
  activities             ActivityLog[]
  settings               OrganizationSettings?
  emailMessages          EmailMessage[]
  owners                 Owner[]
  ownerContacts          OwnerContact[]
  contactTouches         ContactTouch[]
  diligenceItems         OpportunityDiligenceItem[]
  ownerMerges            OwnerMergeRecord[]
  observations           Observation[]
  signals                IntelligenceSignal[]
  refreshJobs            RefreshJob[]
  matchDecisions         OwnerMatchDecision[]
  propertyResolutions    PropertyResolution[]
  propertyMatchDecisions PropertyMatchDecision[]
  underwritings          Underwriting[]
  closingTemplates       ClosingChecklistTemplate[]
  closingChecklists      ClosingChecklist[]
  escrowRecords          EscrowRecord[]
  escrowEvents           EscrowEvent[]
  financingRecords       FinancingRecord[]
  assignmentRecords      AssignmentRecord[]
  automationJobs         AutomationJob[]
  automationExecutions   AutomationExecution[]

  @@map("organizations")
}

// ── Provenance ledger (v1.2, Commit 1b-1) ────────────────────────────────────
// The raw-capture layer: every inbound datum enters here FIRST, immutably.
// Observations that are rejected still persist (they simply never yield a
// Signal). Append-only — never edited or deleted. See Volume 12 §3.
model Observation {
  id                   String                 @id @default(cuid())
  organizationId       String
  entityType           IntelligenceEntityType
  entityId             String
  fieldKey             String
  valueType            String
  valueRaw             String
  valueNormalized      String?
  sourceCategory       SourceCategory
  sourceId             String
  licenseRef           String?
  asOf                 DateTime
  retrievedAt          DateTime               @default(now())
  confidence           Float                  @default(1)
  method               String
  // Which adapter (and its logic version) produced this observation, when it came
  // from a SourceAdapter (Commit 1c). Null for direct user writes, which have no
  // adapter. Lets us trace a datum to the exact adapter logic that emitted it.
  adapterVersion       Int?
  schemaVersion        Int                    @default(1)
  normalizationVersion Int                    @default(1)
  createdAt            DateTime               @default(now())
  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  signal               IntelligenceSignal?

  @@index([organizationId])
  @@index([entityType, entityId, fieldKey])
  @@map("observations")
}

// Accepted intelligence: an Observation promoted into the canonical ledger.
// IMMUTABLE — a correction is a NEW signal that SUPERSEDES the prior (never an
// edit/delete). Multiple ACCEPTED signals may coexist per field (one per source
// lineage); the projection winner is chosen by precedence in 1b-2.
model IntelligenceSignal {
  id                   String                 @id @default(cuid())
  organizationId       String
  entityType           IntelligenceEntityType
  entityId             String
  fieldKey             String
  valueType            String
  valueRaw             String
  valueNormalized      String?
  sourceCategory       SourceCategory
  sourceId             String
  licenseRef           String?
  asOf                 DateTime
  retrievedAt          DateTime               @default(now())
  confidence           Float                  @default(1)
  method               String
  state                SignalState            @default(ACCEPTED)
  isOverride           Boolean                @default(false)
  observationId        String                 @unique
  supersededById       String?
  // Carried from the originating observation (Commit 1c) — null for direct writes.
  adapterVersion       Int?
  schemaVersion        Int                    @default(1)
  normalizationVersion Int                    @default(1)
  projectionVersion    Int                    @default(1)
  createdAt            DateTime               @default(now())
  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  observation          Observation            @relation(fields: [observationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([entityType, entityId, fieldKey, state])
  @@index([supersededById])
  @@map("intelligence_signals")
}

// ── Refresh (v1.2, Commit 1c) ────────────────────────────────────────────────
// One durable record per refresh run — the SOLE audit surface for ingestion (no
// separate event stream). A RefreshJob captures who ran it, which adapter, the
// target, the counts, timing, and the outcome. It is also the idempotency
// anchor: (organizationId, sourceKey, requestKey) is unique, so re-submitting an
// identical run returns the existing job instead of applying it twice. Refresh is
// OBSERVATIONAL — it only creates Observations/Signals and triggers Projection;
// it never creates/merges/splits Owners and never deletes (Volume 12).
model RefreshJob {
  id                   String                 @id @default(cuid())
  organizationId       String
  sourceKey            String
  status               RefreshJobStatus       @default(RUNNING)
  requestKey           String // client-supplied or server content-hash (idempotency)
  targetEntityType     IntelligenceEntityType
  targetEntityId       String
  observationsRecorded Int                    @default(0)
  signalsAccepted      Int                    @default(0)
  signalsSuperseded    Int                    @default(0)
  affectedEntityIds    String[] // entities whose projection was recomputed
  actorUserId          String?
  error                String?
  startedAt            DateTime?
  finishedAt           DateTime?
  createdAt            DateTime               @default(now())
  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, sourceKey, requestKey])
  @@index([organizationId, status])
  @@map("refresh_jobs")
}

// ── Candidate Review (v1.2, Commit 1d-2b) ────────────────────────────────────
// A human's decision about a *possible* owner-duplicate pair. Decision-support
// ONLY: it records judgement, never structural identity change. The pair is
// stored in a canonical unordered form (ownerIdA < ownerIdB) so a decision is
// order-independent; owner ids are scalars, not FKs, so a later merge/tombstone
// of one side never cascade-deletes decision history. `signalFingerprint` snap-
// shots the pair's identity state (matchKey + normalized aliases) so a DISMISSED
// pair re-surfaces only on a material identity change (or explicit ADMIN reopen).
model OwnerMatchDecision {
  id                String           @id @default(cuid())
  organizationId    String
  ownerIdA          String // canonical: lexicographically smaller owner id
  ownerIdB          String // larger owner id
  status            OwnerMatchStatus
  reason            String? // match reason at decision time (audit): exact-match-key | alias-match
  signalFingerprint String // identity-state fingerprint → material-change detection
  note              String?
  decidedByUserId   String?
  decidedAt         DateTime         @default(now())
  reopenedByUserId  String? // set on explicit ADMIN reopen
  reopenedAt        DateTime? // when set, the decision is inactive (pair pending again)
  // Merge resolution (Commit 1d-3b). A CONFIRMED, active, unresolved decision is
  // "awaiting merge"; a merge CONSUMES it, stamping these. The status stays
  // CONFIRMED (there is no MERGED status) — resolution is modeled here. Unmerge
  // CLEARS these three, returning the still-CONFIRMED pair to the merge queue.
  // mergeRecordId is @unique so one merge record can resolve at most one decision.
  resolvedAt        DateTime? // set when a merge consumed this decision
  resolvedByUserId  String?
  mergeRecordId     String?          @unique // the OwnerMergeRecord produced (scalar; no FK — history-safe)
  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, ownerIdA, ownerIdB])
  @@index([organizationId, status])
  @@map("owner_match_decisions")
}

// ── Commercial Intelligence (v1.2, Slice 1 / Commit 1a) ──────────────────────
// Owner: the durable, canonical title-holding party (Volume 12 §2). Distinct
// from Seller (the transaction counterparty). In 1a, displayName/entityType are
// written directly; in 1b they become projections driven from the signal ledger.
model Owner {
  id             String                    @id @default(cuid())
  organizationId String
  displayName    String
  entityType     OwnerEntityType           @default(UNKNOWN)
  status         OwnerStatus               @default(ACTIVE)
  matchKey       String // normalized identity key; NOT unique (owners may share a normalized name)
  mergedIntoId   String? // set on a MERGED loser → its surviving winner (Commit 1a-2)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mergedInto     Owner?                    @relation("OwnerMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom     Owner[]                   @relation("OwnerMerge")
  aliases        OwnerAlias[]
  externalIds    OwnerExternalIdentifier[]
  contacts       OwnerContact[]
  sellers        Seller[]
  properties     Property[]

  @@index([organizationId])
  @@index([status])
  @@index([matchKey])
  @@index([mergedIntoId])
  @@map("owners")
}

model OwnerContact {
  id                     String                @id @default(cuid())
  organizationId         String
  ownerId                String
  label                  String?
  contactName            String?
  company                String?
  email                  String?
  phone                  String?
  mailingAddress         String?
  notes                  String?
  isPrimary              Boolean               @default(false)
  outreachStatus         ContactOutreachStatus @default(NEW)
  preferredContactMethod ContactMethod?
  nextFollowUpAt         DateTime?
  assignedUserId         String?
  doNotCall              Boolean               @default(false)
  doNotEmail             Boolean               @default(false)
  doNotText              Boolean               @default(false)
  badPhone               Boolean               @default(false)
  badEmail               Boolean               @default(false)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  organization           Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner                  Owner                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  assignedUser           User?                 @relation("OwnerContactAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  touchHistory           ContactTouch[]

  @@index([organizationId])
  @@index([ownerId])
  @@index([assignedUserId])
  @@map("owner_contacts")
}

model ContactTouch {
  id             String           @id @default(cuid())
  organizationId String
  ownerContactId String?
  sellerId       String?
  buyerId        String?
  type           ContactTouchType
  summary        String?
  createdById    String?
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerContact   OwnerContact?    @relation(fields: [ownerContactId], references: [id], onDelete: SetNull)
  seller         Seller?          @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  buyer          Buyer?           @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  createdBy      User?            @relation("ContactTouchActor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([ownerContactId])
  @@index([sellerId])
  @@index([buyerId])
  @@index([createdById])
  @@map("contact_touches")
}

// Reversible, audited record of an owner merge (Commit 1a-2). Structural only —
// it captures the graph changes needed to unmerge exactly (repointed links +
// merge-derived aliases), never business data (Volume 12 "merge is structural").
// Scalar-list columns hold the reversal payload; the record is append-only
// (status flips ACTIVE → REVERSED on unmerge, never deleted).
model OwnerMergeRecord {
  id               String           @id @default(cuid())
  organizationId   String
  winnerId         String
  loserId          String
  reason           OwnerMergeReason
  note             String?
  status           OwnerMergeStatus @default(ACTIVE)
  movedSellerIds   String[]
  movedPropertyIds String[]
  addedAliasIds    String[]
  mergedByUserId   String?
  mergedAt         DateTime         @default(now())
  reversedByUserId String?
  reversedAt       DateTime?
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([winnerId])
  @@index([loserId])
  @@index([status])
  @@map("owner_merge_records")
}

// Alternate/normalized names used to PROPOSE candidate matches (never to link
// automatically — Volume 12 S1-4). sourceCategory is a lightweight attribution
// in 1a; the full provenance-ledger link arrives in 1b.
model OwnerAlias {
  id              String   @id @default(cuid())
  ownerId         String
  value           String
  normalizedValue String
  sourceCategory  String
  createdAt       DateTime @default(now())
  owner           Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([normalizedValue])
  @@map("owner_aliases")
}

// The authoritative identity crosswalk (Volume 12 §7, S1-4). IMMUTABLE: rows are
// never edited, reassigned, or deleted — a changed mapping is a NEW row. Empty
// until a provider adapter exists, but the mechanism ships now.
model OwnerExternalIdentifier {
  id             String    @id @default(cuid())
  organizationId String
  ownerId        String
  provider       String
  externalId     String
  asOf           DateTime?
  createdAt      DateTime  @default(now())
  owner          Owner     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider, externalId])
  @@index([ownerId])
  @@map("owner_external_identifiers")
}

// Org-wide defaults, one row per organization. The single home for all
// organization configuration — accessed only through lib/org-settings.
model OrganizationSettings {
  id                String       @id @default(cuid())
  organizationId    String       @unique
  inviteExpiryDays  Int          @default(7)
  defaultInviteRole UserRole     @default(ACQUISITIONS)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

// Outbound email ledger (the "outbox"). One row per send attempt-target, written
// by lib/email/message-service BEFORE the transport is invoked, then advanced to
// SENT/FAILED. Deliberately stores METADATA ONLY — never the rendered html/text,
// invitation/reset links, tokens, or secrets (same philosophy as invitation
// token hashes). `templateVersion` gives reproducibility without retaining the
// body: support can reconstruct "what would have been sent" from template + data
// context. PENDING/FAILED rows with attempts < maxAttempts are the drain target.
model EmailMessage {
  id                String        @id @default(cuid())
  organizationId    String? // nullable: some system emails aren't org-scoped
  toEmail           String
  template          String // MessageKind vocabulary (open, like ActivityLog.eventType)
  templateVersion   Int           @default(1)
  subject           String // metadata only — never the body
  status            EmailStatus   @default(PENDING)
  attempts          Int           @default(0)
  maxAttempts       Int           @default(3)
  providerMessageId String?
  error             String?
  correlationId     String? // ties to the triggering entity (invitationId, …)
  lastAttemptAt     DateTime?
  sentAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([organizationId])
  @@map("email_messages")
}

model Seller {
  id                     String                @id @default(cuid())
  organizationId         String
  ownerId                String? // v1.2: the canonical Owner this deal contact represents (nullable, additive)
  name                   String
  company                String?
  email                  String?
  phone                  String?
  motivation             String?
  city                   String?
  state                  String?
  outreachStatus         ContactOutreachStatus @default(NEW)
  preferredContactMethod ContactMethod?
  nextFollowUpAt         DateTime?
  assignedUserId         String?
  doNotCall              Boolean               @default(false)
  doNotEmail             Boolean               @default(false)
  doNotText              Boolean               @default(false)
  badPhone               Boolean               @default(false)
  badEmail               Boolean               @default(false)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  organization           Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner                  Owner?                @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  assignedUser           User?                 @relation("SellerAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  properties             Property[]
  opportunities          Opportunity[]
  notes                  Note[]
  documents              Document[]
  activities             ActivityLog[]
  touchHistory           ContactTouch[]

  @@index([organizationId])
  @@index([ownerId])
  @@index([assignedUserId])
  @@map("sellers")
}

model Buyer {
  id                     String                @id @default(cuid())
  organizationId         String
  name                   String
  company                String?
  email                  String?
  phone                  String?
  targetAssetTypes       AssetType[]
  targetStates           String[]
  minimumPurchaseUsd     Int?
  maximumPurchaseUsd     Int?
  outreachStatus         ContactOutreachStatus @default(NEW)
  preferredContactMethod ContactMethod?
  nextFollowUpAt         DateTime?
  assignedUserId         String?
  doNotCall              Boolean               @default(false)
  doNotEmail             Boolean               @default(false)
  doNotText              Boolean               @default(false)
  badPhone               Boolean               @default(false)
  badEmail               Boolean               @default(false)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  organization           Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedUser           User?                 @relation("BuyerAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  matches                BuyerMatch[]
  notes                  Note[]
  documents              Document[]
  activities             ActivityLog[]
  touchHistory           ContactTouch[]

  @@index([organizationId])
  @@index([assignedUserId])
  @@map("buyers")
}

model Property {
  id                  String                       @id @default(cuid())
  organizationId      String
  sellerId            String?
  ownerId             String? // v1.2: the canonical Owner that holds title (nullable, additive)
  name                String
  assetType           AssetType
  addressLine1        String
  city                String
  state               String
  postalCode          String?
  county              String?
  unitCount           Int?
  squareFeet          Int?
  acreage             Float?
  yearBuilt           Int?
  occupancyRate       Float?
  askingPriceUsd      Int?
  estimatedValueUsd   Int?
  noiAnnualUsd        Int?
  capRate             Float?
  status              String?
  // v1.2 Commit 2c-i: ledger-backed projected identity ANCHORS (evidence, not identity).
  apnNormalized       String?
  countyFipsCode      String?
  addressNormalized   String?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  organization        Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  seller              Seller?                      @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  owner               Owner?                       @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  opportunities       Opportunity[]
  analyses            DealAnalysis[]
  documents           Document[]
  notes               Note[]
  activities          ActivityLog[]
  identity            PropertyIdentity?
  externalIdentifiers PropertyExternalIdentifier[]

  @@index([organizationId])
  @@index([sellerId])
  @@index([ownerId])
  @@map("properties")
}

// v1.2 Commit 2c-i — the DERIVED, rebuildable Property identity surface (PI-A).
// NOT a source of truth: every column is derived purely from the accepted anchor
// signals in the ledger by rebuildPropertyIdentity (deterministic, invariant #12).
// `rebuiltFromProjectionAt` is the deterministic projection watermark (max winning
// anchor-signal createdAt), never wall-clock. One row per property.
model PropertyIdentity {
  id                      String    @id @default(cuid())
  organizationId          String
  propertyId              String    @unique
  countyFipsCode          String?
  apnNormalized           String?
  addressNormalized       String?
  parcelKey               String? // "${countyFipsCode}|${apnNormalized}" — only when both present
  identityVersion         String // deterministic fingerprint of the winning anchor set + normalizer versions
  rebuiltFromProjectionAt DateTime?
  property                Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([organizationId, parcelKey])
  @@index([organizationId, addressNormalized])
  @@map("property_identities")
}

enum ExternalIdentifierState {
  ACTIVE
  SUPERSEDED
}

// v1.2 Commit 2c-i — the immutable external-identifier crosswalk (R3). Append-only
// with Signal-style supersession: rows are never edited or deleted; a remap
// supersedes the prior ACTIVE row and inserts a new one. At most one ACTIVE row per
// (organizationId, provider, providerIdentifier), enforced transactionally.
model PropertyExternalIdentifier {
  id                    String                  @id @default(cuid())
  organizationId        String
  propertyId            String
  provider              String
  providerIdentifier    String
  asOf                  DateTime?
  state                 ExternalIdentifierState @default(ACTIVE)
  supersededById        String?
  // v1.2 Commit 2c-ii: set when a resolution REVERSAL revokes this attachment
  // (ACTIVE → SUPERSEDED with supersededById null). A revocation, not a remap; the
  // identifier value is never rewritten — the same append-only lifecycle transition.
  revokedByResolutionId String?
  createdAt             DateTime                @default(now())
  property              Property                @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([organizationId, provider, providerIdentifier])
  @@index([organizationId, propertyId])
  @@map("property_external_identifiers")
}

// v1.2 Commit 2c-ii — Property identity RESOLUTION audit + candidate governance.
// Resolution sits between identity structure (2c-i) and human workflow (2c-iii): a
// deterministic classification engine that decides how inbound evidence attaches to
// a canonical Property. It NEVER modifies evidence (locked invariant) and never
// merges/deletes/repoints — it only appends and deterministically rebuilds.

enum ResolutionBasis {
  UNIQUE_PARCEL
  UNIQUE_EXTERNAL_IDENTIFIER
  PARCEL_CONFLICT
  ADDRESS_PROPOSAL
  EXTERNAL_ID_CONFLICT
}

enum ResolutionEventKind {
  RESOLVE
  REVERSAL
}

// The append-only Resolution audit log. Every guarded Tier-1A resolve-before-create
// appends a RESOLVE event; a reversal appends a REVERSAL event that SUPERSEDES it —
// a first-class historical event (actor + reason + time + affected resolution). The
// original row is never mutated. `basis` is deterministic explanatory metadata (why
// this path was taken) and NEVER an input to behavior. Property ids are scalars (no
// FK) so audit history survives a later Property change (mirrors OwnerMatchDecision);
// the org relation cascades for lifecycle cleanup only.
model PropertyResolution {
  id                            String              @id @default(cuid())
  organizationId                String
  kind                          ResolutionEventKind
  resolvedPropertyId            String
  basis                         ResolutionBasis
  evidence                      Json // normalized anchors + external ids snapshot at decision time
  attachedExternalIdentifierIds Json // crosswalk row ids this RESOLVE attached (read by a REVERSAL)
  reason                        String?
  requestKey                    String? // idempotent replay of a RESOLVE (unique per org)
  supersedesResolutionId        String? // REVERSAL → the RESOLVE it reverses
  actorUserId                   String?
  createdAt                     DateTime            @default(now())
  organization                  Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, requestKey])
  @@index([organizationId, resolvedPropertyId])
  @@map("property_resolutions")
}

enum PropertyMatchStatus {
  PENDING
  CONFIRMED
  DISMISSED
}

// A human's decision about a POSSIBLE Property-identity match surfaced by resolution
// (Tier 1B / Tier 2). Decision-support ONLY: it records judgement, never a structural
// change (no merge/create/delete/repoint, no Signal write) — a CONFIRMED pair feeds a
// future (deferred) merge. Canonical unordered pair (propertyIdA < propertyIdB) so a
// decision is order-independent; property ids are scalars (no FK) so history survives.
// `evidenceFingerprint` snapshots both sides' identityVersion + basis so a DISMISSED
// pair re-surfaces only on a MATERIAL identity change (or explicit ADMIN reopen).
// Mirrors OwnerMatchDecision.
model PropertyMatchDecision {
  id                  String              @id @default(cuid())
  organizationId      String
  propertyIdA         String // canonical: lexicographically smaller property id
  propertyIdB         String // larger property id
  basis               ResolutionBasis
  status              PropertyMatchStatus
  evidenceFingerprint String // identity-state fingerprint → material-change detection
  reason              String?
  note                String?
  decidedByUserId     String?
  decidedAt           DateTime? // set when confirmed / dismissed
  reopenedByUserId    String?
  reopenedAt          DateTime? // when set, the decision is inactive (pair pending again)
  createdAt           DateTime            @default(now())
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, propertyIdA, propertyIdB])
  @@index([organizationId, status])
  @@map("property_match_decisions")
}

model Opportunity {
  id               String            @id @default(cuid())
  organizationId   String
  propertyId       String
  sellerId         String?
  title            String
  stage            OpportunityStage  @default(LEAD)
  source           String?
  priority         String?
  targetCloseDate  DateTime?
  contractValueUsd Int?
  assignmentFeeUsd Int?
  summary          String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property         Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  seller           Seller?           @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  analysis         DealAnalysis?
  underwriting     Underwriting?
  closingChecklist ClosingChecklist?
  escrow           EscrowRecord?
  financing        FinancingRecord?
  assignment       AssignmentRecord?
  diligenceItems   OpportunityDiligenceItem[]
  tasks            Task[]
  notes            Note[]
  documents        Document[]
  buyerMatches     BuyerMatch[]
  activities       ActivityLog[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([sellerId])
  @@map("opportunities")
}

model OpportunityDiligenceItem {
  id             String                    @id @default(cuid())
  organizationId String
  opportunityId  String
  key            String
  label          String
  position       Int
  status         OpportunityDiligenceStatus @default(NOT_REQUESTED)
  requestedAt    DateTime?
  receivedAt     DateTime?
  reviewedAt     DateTime?
  notes          String?
  documentId     String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity    Opportunity               @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, key])
  @@index([organizationId])
  @@index([opportunityId, position])
  @@map("opportunity_diligence_items")
}

// DEPRECATED (v1.3, Commit 3a). DealAnalysis is superseded by the canonical
// Underwriting → UnderwritingScenario → UnderwritingAssumption → ScenarioResult
// model below. Retained (not dropped) for one accepted release so the ownership
// change can be proven stable before the table is removed (founder decision D-7).
// No code writes or reads it after the 3a analyzer repoint.
model DealAnalysis {
  id                   String       @id @default(cuid())
  organizationId       String
  propertyId           String
  opportunityId        String       @unique
  purchasePriceUsd     Int
  renovationBudgetUsd  Int?
  closingCostsUsd      Int?
  grossIncomeAnnualUsd Int?
  operatingExpensesUsd Int?
  loanAmountUsd        Int?
  interestRatePct      Float?
  amortizationYears    Int?
  noiAnnualUsd         Int?
  capRate              Float?
  dscr                 Float?
  debtYield            Float?
  pricePerUnitUsd      Float?
  analystSummary       String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property             Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  opportunity          Opportunity  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([propertyId])
  @@map("deal_analysis")
}

// --- Commercial Underwriting (v1.3, Commit 3a) --------------------------------
// The canonical deterministic underwriting model. Underwriting anchors on the
// Opportunity (U-G); a Scenario owns a frozen set of Assumptions; a ScenarioResult
// owns the deterministic calculations derived from those assumptions + model
// lineage (U-L). Every deterministic output belongs to exactly one Scenario.
// Property context enters ONCE as SEEDED assumptions (a one-way snapshot — a
// Scenario never changes because the underlying Property changes); the analyst's
// inputs are MANUAL assumptions. Reconstruction reads only frozen assumptions +
// model lineage + the pure calculation kernel — never current Property state.
enum ScenarioStatus {
  DRAFT
  LOCKED
  SUPERSEDED
}

enum AssumptionSource {
  MANUAL // authored by the analyst
  SEEDED // snapshotted from the Version 1.2 platform at scenario creation (a ScenarioSeed value)
}

enum AssumptionKey {
  PURCHASE_PRICE
  RENOVATION_BUDGET
  CLOSING_COSTS
  GROSS_INCOME
  OPERATING_EXPENSES
  LOAN_AMOUNT
  INTEREST_RATE
  AMORTIZATION_YEARS
  UNIT_COUNT
  ESTIMATED_VALUE
  // Debt-sizing constraints (v1.3, Commit 3b-i). Optional analyst inputs — not
  // kernel inputs; consumed only by the pure debt-sizing calculation. As of 3b-iii
  // these are CAPITAL assumptions, owned by a FinancingCase (CF-1), not the Scenario.
  TARGET_LTV_PCT
  TARGET_LTC_PCT
  MIN_DSCR
  // Projection assumptions (v1.3, Commit 3b-iii). OPERATING inputs (financing-
  // independent, CF-5): they shape the shared NOI trajectory, not the debt.
  INCOME_GROWTH_PCT
  EXPENSE_GROWTH_PCT
  HOLD_YEARS
  // Exit assumptions (v1.3, Commit 3b-iv). OPERATING (market/transaction, financing-
  // independent): the terminal valuation is the same regardless of capital structure;
  // each case then nets its own debt payoff. The exit year is the hold period.
  EXIT_CAP_RATE_PCT
  SELLING_COSTS_PCT
}

// Which constraint bound the sized loan (v1.3, Commit 3b-i).
enum DebtSizingConstraint {
  LTV
  LTC
  DSCR
}

// A scenario income/expense schedule line (v1.3, Commit 3b-ii).
enum LineItemKind {
  INCOME
  EXPENSE
}

model Underwriting {
  id               String                 @id @default(cuid())
  organizationId   String
  opportunityId    String                 @unique
  // Scalar snapshot of the property underwritten — deliberately NOT an FK, so the
  // underwriting never couples back onto the Property graph (U-G).
  propertyId       String
  activeScenarioId String?
  createdByUserId  String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity      Opportunity            @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  scenarios        UnderwritingScenario[]

  @@index([organizationId])
  @@map("underwritings")
}

model UnderwritingScenario {
  id              String                   @id @default(cuid())
  organizationId  String
  underwritingId  String
  label           String
  version         Int
  status          ScenarioStatus           @default(DRAFT)
  // Model lineage (U-K) frozen onto every scenario at creation.
  modelVersion    Int
  calcLibVersion  Int
  rulesetVersion  Int
  // Deterministic fingerprint of (assumption set + canonical ordering + model
  // lineage). Makes Scenario → ScenarioVersion → ScenarioResult explicit and
  // distinguishes an assumption change from a calculation-model change.
  scenarioVersion String
  // Analyst narrative for this scenario. A note, NOT a deterministic output — it
  // is deliberately excluded from scenarioVersion and from ScenarioResult.
  analystSummary  String?
  supersededById  String?
  createdByUserId String?
  createdAt       DateTime                 @default(now())
  lockedAt        DateTime?
  underwriting    Underwriting             @relation(fields: [underwritingId], references: [id], onDelete: Cascade)
  assumptions     UnderwritingAssumption[]
  lineItems       ScenarioLineItem[]
  result          ScenarioResult?
  financingCases  FinancingCase[]
  findings        ScenarioFinding[]
  recommendation  ScenarioRecommendation?
  decisions       UnderwritingDecision[]

  @@unique([underwritingId, version])
  @@index([organizationId])
  @@map("underwriting_scenarios")
}

model UnderwritingAssumption {
  id             String               @id @default(cuid())
  organizationId String
  scenarioId     String
  key            AssumptionKey
  // Decimal in persistence for exact monetary/rate storage; converted to a JS
  // number deterministically at the boundary into the pure kernel (D-6).
  valueNumeric   Decimal
  source         AssumptionSource
  // Provenance for SEEDED assumptions: which platform field, and its as-of.
  sourceField    String?
  sourceAsOf     DateTime?
  createdAt      DateTime             @default(now())
  scenario       UnderwritingScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@unique([scenarioId, key])
  @@index([organizationId])
  @@map("underwriting_assumptions")
}

model ScenarioResult {
  id                   String               @id @default(cuid())
  organizationId       String
  scenarioId           String               @unique
  // The scenarioVersion this result was derived from (staleness detection).
  scenarioVersion      String
  calcLibVersion       Int
  // Effective income/expense used for NOI (v1.3, Commit 3b-ii) — the rolled-up
  // schedule total when a schedule exists, else the scalar assumption.
  grossIncomeAnnualUsd Int?
  operatingExpensesUsd Int?
  noiAnnualUsd         Int?
  allInCostUsd         Int
  capRate              Float?
  pricePerUnitUsd      Float?
  expenseRatioPct      Float?
  spreadUsd            Int?
  // OPERATING-ONLY (v1.3, Commit 3b-iii): every financing-dependent metric
  // (debt service, DSCR, debt yield, debt sizing) relocated to FinancingCaseResult
  // per CF-1/CF-2 — a Scenario's result carries no financing economics.
  scenario             UnderwritingScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("scenario_results")
}

// One income or expense line on a scenario's schedule (v1.3, Commit 3b-ii). Income
// lines roll up to the effective gross income and expense lines to the effective
// operating expenses, feeding the unchanged kernel. Belongs to exactly one Scenario;
// `source` mirrors assumptions (MANUAL analyst input; SEEDED reserved). `position`
// is presentation ordering only — it is excluded from the deterministic fingerprint.
model ScenarioLineItem {
  id              String               @id @default(cuid())
  organizationId  String
  scenarioId      String
  kind            LineItemKind
  category        String
  amountAnnualUsd Decimal
  position        Int
  source          AssumptionSource
  createdAt       DateTime             @default(now())
  scenario        UnderwritingScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([scenarioId])
  @@map("scenario_line_items")
}

// One capital structure alternative under a Scenario (v1.3, Commit 3b-iii). A
// FinancingCase consumes the Scenario's frozen operating economics (CF-4/CF-5) and
// owns its own capital inputs + financing-dependent outputs — so debt, all-cash,
// seller-financing, mezzanine, or preferred-equity alternatives can be compared
// side by side without touching the operating model.
model FinancingCase {
  id                   String                @id @default(cuid())
  organizationId       String
  scenarioId           String
  label                String
  position             Int
  source               AssumptionSource
  // Deterministic per-case fingerprint (CF-3): sha256(operating scenarioVersion +
  // sorted capital assumptions + model lineage). Each case is independently
  // reproducible and independently comparable.
  financingCaseVersion String
  createdAt            DateTime              @default(now())
  scenario             UnderwritingScenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  capitalAssumptions   FinancingAssumption[]
  result               FinancingCaseResult?
  cashFlow             CashFlowYear[]
  equityCashFlow       EquityCashFlowYear[]
  sensitivity          SensitivityAnalysis?

  @@index([organizationId])
  @@index([scenarioId])
  @@map("financing_cases")
}

// A capital input owned by a FinancingCase (CF-1). Mirrors UnderwritingAssumption
// exactly, but scoped to the capital structure rather than the operating Scenario.
model FinancingAssumption {
  id              String           @id @default(cuid())
  organizationId  String
  financingCaseId String
  key             AssumptionKey
  valueNumeric    Decimal
  source          AssumptionSource
  sourceField     String?
  sourceAsOf      DateTime?
  createdAt       DateTime         @default(now())
  financingCase   FinancingCase    @relation(fields: [financingCaseId], references: [id], onDelete: Cascade)

  @@unique([financingCaseId, key])
  @@index([organizationId])
  @@map("financing_assumptions")
}

// The financing-dependent summary for one FinancingCase (relocated from
// ScenarioResult per CF-2). Derived, cached, content-idempotent, rebuildable —
// 1:1 with a FinancingCase.
model FinancingCaseResult {
  id                    String                @id @default(cuid())
  organizationId        String
  financingCaseId       String                @unique
  financingCaseVersion  String
  calcLibVersion        Int
  // Debt service on the case's amortizing loan (Float — a 2-decimal payment).
  annualDebtServiceUsd  Float?
  dscr                  Float?
  debtYieldPct          Float?
  // Debt sizing (relocated from 3b-i): the loan the case's constraints permit.
  loanByLtvUsd          Int?
  loanByLtcUsd          Int?
  loanByDscrUsd         Int?
  sizedLoanUsd          Int?
  bindingConstraint     DebtSizingConstraint?
  // Multi-year operating cash-flow aggregates for this case. cumulativeCashFlowUsd
  // is the cumulative operating equity cash flow (levered CF before tax over the hold).
  projectionYears       Int?
  avgDscr               Float?
  cumulativeCashFlowUsd Int?
  // Exit valuation + returns (v1.3, Commit 3b-iv). Null when no exit is modeled (no
  // hold period or no exit cap rate). The EX-2 set is fully persisted so the terminal
  // value is independently reproducible; returns are pure functions of the equity
  // cash-flow series (EX-4). All operating cash flow only — no tax/refinance/promote.
  terminalNoiUsd        Float?
  exitCapRatePct        Float?
  sellingCostsPct       Float?
  grossExitValueUsd     Float?
  sellingCostsUsd       Float?
  debtPayoffUsd         Float?
  netSaleProceedsUsd    Float?
  contributedEquityUsd  Float?
  equityMultiple        Float?
  leveredIrrPct         Float?
  totalProfitUsd        Float?
  financingCase         FinancingCase         @relation(fields: [financingCaseId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("financing_case_results")
}

// The DECIDED recommendation (v1.3, Commit 3d) — the U-B human half. Fundamentally
// different from every calculation surface: non-deterministic, AUTHORED, and TERMINAL.
// It lives OUTSIDE the pure engine (UW-4) and never feeds back into it (Principle 7 /
// UW-7 / AP-3). It is an OPERATIONAL record — NOT a calculation artifact: no lineage, no
// fingerprint, no version, no rebuild. A decision is recorded only against a LOCKED
// Scenario (AP-2), is append-only + immutable (AP-4 — a change appends a higher-sequence
// row; nothing is mutated/deleted), and captures the immutable snapshot it was made
// against (AP-6). Governed by the separate UNDERWRITING_APPROVAL resource (AP-5).
enum UnderwritingDecisionLevel {
  APPROVED
  DECLINED
  DEFERRED
}

model UnderwritingDecision {
  id              String                    @id @default(cuid())
  organizationId  String
  scenarioId      String
  underwritingId  String // denormalized for scoping (set at record time)
  // Per-scenario monotonic order; the highest sequence is the current decision.
  sequence        Int
  decision        UnderwritingDecisionLevel
  rationale       String
  // Immutable snapshot the human reviewed (AP-6) — read from the scenario/recommendation,
  // never recomputed here.
  scenarioVersion String
  findingsVersion String?
  suggestedLevel  RecommendationLevel? // the engine's suggestion at decision time (for contrast)
  actorUserId     String
  createdAt       DateTime                  @default(now())
  scenario        UnderwritingScenario      @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@unique([scenarioId, sequence])
  @@index([organizationId])
  @@index([scenarioId])
  @@map("underwriting_decisions")
}

// Findings / Risks / Suggested Recommendation (v1.3, Commit 3b-vi). The TOP consumer
// layer (FR-1): a pure, fixed, versioned ruleset reads the settled deterministic outputs
// and emits per-Scenario findings + one advisory recommendation. It NEVER feeds back into
// any calculation (Principle 7 / UW-7) and the engine never decides (UW-4 / FR-5). Keyed
// by `findingsVersion` (RULESET_VERSION lives here ONLY — R-A / FR-6), so a rules change
// never invalidates a metric.
enum FindingSeverity {
  INFO
  WARNING
  CRITICAL
}

enum FindingCategory {
  DEAL_QUALITY
  FINANCING
  CASH_FLOW
  RETURN
}

enum RecommendationLevel {
  PROCEED
  PROCEED_WITH_CONDITIONS
  PASS
}

// One finding on a Scenario (FR-2). It may CITE a FinancingCase (financingCaseId) but is
// owned by the Scenario — the reference is a plain id (findings are fully rebuilt on any
// case change, so no FK/cascade is needed). `decisive` marks the findings that drive the
// recommendation (operating + the primary case). Disposable + rebuildable (FR-3).
model ScenarioFinding {
  id              String               @id @default(cuid())
  organizationId  String
  scenarioId      String
  financingCaseId String?
  code            String
  category        FindingCategory
  severity        FindingSeverity
  decisive        Boolean              @default(true)
  title           String
  detail          String
  observedValue   Float?
  thresholdValue  Float?
  position        Int
  scenario        UnderwritingScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([scenarioId])
  @@map("scenario_findings")
}

// The single suggested recommendation for a Scenario (1:1). Advisory only (FR-5): derived
// deterministically from the decisive findings, never modifying an underwriting result.
model ScenarioRecommendation {
  id              String               @id @default(cuid())
  organizationId  String
  scenarioId      String               @unique
  level           RecommendationLevel
  findingsVersion String
  rulesetVersion  Int
  createdAt       DateTime             @default(now())
  scenario        UnderwritingScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("scenario_recommendations")
}

// A sensitivity analysis over ONE FinancingCase (v1.3, Commit 3b-v). A CONSUMER of
// the engine (Principle 10): it re-derives the case over perturbed inputs and stores
// the resulting metric per cell — it NEVER mutates the baseline Scenario/case (SE-1)
// and never optimizes (SE-7). The spec is analyst input; the cells are derived,
// disposable, and rebuildable (SE-4).
enum SensitivityMetric {
  LEVERED_IRR_PCT
  EQUITY_MULTIPLE
  TOTAL_PROFIT_USD
  CAP_RATE
  DSCR
}

model SensitivityAnalysis {
  id                 String            @id @default(cuid())
  organizationId     String
  financingCaseId    String            @unique
  targetMetric       SensitivityMetric
  // X axis (required). An assumption key from the fixed allow-list + a deterministic
  // evenly-spaced range (SE-5). Steps 1..11; the full matrix is capped at 121 cells.
  xKey               AssumptionKey
  xMin               Float
  xMax               Float
  xSteps             Int
  // Y axis (optional — absent ⇒ a one-axis/degenerate analysis).
  yKey               AssumptionKey?
  yMin               Float?
  yMax               Float?
  ySteps             Int?
  // Fingerprint = f(financingCaseVersion, canonical spec, lineage).
  sensitivityVersion String
  calcLibVersion     Int
  createdAt          DateTime          @default(now())
  financingCase      FinancingCase     @relation(fields: [financingCaseId], references: [id], onDelete: Cascade)
  cells              SensitivityCell[]

  @@index([organizationId])
  @@map("sensitivity_analyses")
}

// One derived cell of a sensitivity grid. metricValue is the target metric re-derived
// under this cell's explicit axis overrides (SE-3). isBaseline is true ONLY when the
// baseline assumption values fall EXACTLY on the generated axes (SE-6) — never snapped.
model SensitivityCell {
  id                    String              @id @default(cuid())
  organizationId        String
  sensitivityAnalysisId String
  xIndex                Int
  yIndex                Int
  xValue                Float
  yValue                Float?
  metricValue           Float?
  isBaseline            Boolean             @default(false)
  analysis              SensitivityAnalysis @relation(fields: [sensitivityAnalysisId], references: [id], onDelete: Cascade)

  @@unique([sensitivityAnalysisId, xIndex, yIndex])
  @@index([organizationId])
  @@map("sensitivity_cells")
}

// One entry in a FinancingCase's equity cash-flow series (v1.3, Commit 3b-iv).
// Year 0 is the negative initial equity contribution; years 1..N are the equity
// distributions (the final year combines operating cash flow + net sale proceeds,
// counted once — EX-5). Disposable + rebuildable like CashFlowYear (EX-4).
model EquityCashFlowYear {
  id                String        @id @default(cuid())
  organizationId    String
  financingCaseId   String
  year              Int
  equityCashFlowUsd Float
  financingCase     FinancingCase @relation(fields: [financingCaseId], references: [id], onDelete: Cascade)

  @@unique([financingCaseId, year])
  @@index([organizationId])
  @@map("equity_cash_flow_years")
}

// One year of a FinancingCase's operating cash-flow projection (v1.3, Commit
// 3b-iii). Disposable + rebuildable, like ScenarioResult. NOI is echoed from the
// shared operating trajectory (CF-5); debt service + cash flow are the case's own.
// Operating cash flow only — no sale, terminal value, refinance, or waterfall.
model CashFlowYear {
  id                   String        @id @default(cuid())
  organizationId       String
  financingCaseId      String
  year                 Int
  noiUsd               Float
  debtServiceUsd       Float
  cashFlowBeforeTaxUsd Float
  dscr                 Float?
  financingCase        FinancingCase @relation(fields: [financingCaseId], references: [id], onDelete: Cascade)

  @@unique([financingCaseId, year])
  @@index([organizationId])
  @@map("cash_flow_years")
}

model Task {
  id             String       @id @default(cuid())
  organizationId String
  opportunityId  String?
  ownerId        String?
  title          String
  description    String?
  status         TaskStatus   @default(BACKLOG)
  dueDate        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity    Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  owner          User?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([opportunityId])
  @@index([ownerId])
  @@map("tasks")
}

model Note {
  id             String       @id @default(cuid())
  organizationId String
  opportunityId  String?
  propertyId     String?
  sellerId       String?
  buyerId        String?
  authorId       String?
  body           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity    Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  property       Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  seller         Seller?      @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  buyer          Buyer?       @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  author         User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("notes")
}

model Document {
  id                       String         @id @default(cuid())
  organizationId           String
  opportunityId            String?
  propertyId               String?
  sellerId                 String?
  buyerId                  String?
  uploaderId               String?
  title                    String
  documentType             DocumentType
  storageKey               String
  originalFilename         String?
  mimeType                 String?
  fileSizeBytes            Int?
  // Provenance discriminator (v1.3, offer-memo generation). Existing rows and every
  // human upload are UPLOADED; an offer memo produced from a model is GENERATED.
  origin                   DocumentOrigin @default(UPLOADED)
  // Generation provenance (OM-G) — NULL for UPLOADED documents; the service enforces
  // that a GENERATED offer memo carries the complete set. A generated memo is an
  // immutable, append-only artifact (OM-H): these snapshot exactly what it was built
  // from and are never mutated after creation.
  sourceScenarioId         String? // the LOCKED scenario the memo was generated from
  sourceScenarioVersion    Int? // that scenario's human version number (v1, v2, …)
  scenarioVersionSnapshot  String? // the scenario fingerprint at generation (OM-4)
  findingsVersionSnapshot  String? // the findings fingerprint at generation, if any
  decisionIdSnapshot       String? // the current decision captured, if one existed
  decisionSequenceSnapshot Int? // that decision's per-scenario sequence
  templateVersion          Int? // OFFER_MEMO_TEMPLATE_VERSION (OM-5)
  generatorVersion         Int? // OFFER_MEMO_GENERATOR_VERSION (OM-5)
  snapshotSchemaVersion    Int? // OFFER_MEMO_SNAPSHOT_SCHEMA_VERSION (OM-5)
  contentSnapshot          Json? // the canonical source snapshot the renderer consumed (OM-4)
  contentSha256            String? // SHA-256 of the final stored bytes — historical evidence (OM-6)
  generatedById            String? // the user who generated it (scalar, mirrors decision.actorUserId)
  generatedAt              DateTime? // generation timestamp captured into the snapshot
  generationSequence       Int? // monotonic per (sourceScenarioId, documentType) — append-only (OM-7)
  // Opportunity-anchored generation source (v1.4 Slice 4, AS-E). NULL for scenario-anchored
  // (offer-memo) and uploaded documents; set for a generated ASSIGNMENT_AGREEMENT so the
  // append-only generationSequence is scoped per Opportunity. Keeps the offer-memo path
  // (sourceScenarioId + its unique key) untouched (AS-8).
  sourceOpportunityId      String?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  organization             Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity              Opportunity?   @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  property                 Property?      @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  seller                   Seller?        @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  buyer                    Buyer?         @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  uploader                 User?          @relation(fields: [uploaderId], references: [id], onDelete: SetNull)

  @@unique([sourceScenarioId, documentType, generationSequence])
  // AS-E: opportunity-anchored generated docs (assignment agreement) get their own
  // append-only sequence. Offer-memo/uploaded rows have sourceOpportunityId = NULL, which
  // Postgres treats as distinct, so this never collides with them (AS-8).
  @@unique([sourceOpportunityId, documentType, generationSequence])
  @@index([organizationId])
  @@map("documents")
}

// Closing Center (v1.4) — the versioned SOURCE of checklist requirements (CC-G/CC-9).
// Templates are org-scoped and never hardcoded; instantiating a checklist SNAPSHOTS a
// template's items (CC-10), so later template edits never rewrite an active deal.
model ClosingChecklistTemplate {
  id             String                         @id @default(cuid())
  organizationId String
  name           String
  version        Int                            @default(1)
  isActive       Boolean                        @default(true)
  isDefault      Boolean                        @default(false)
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt
  organization   Organization                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items          ClosingChecklistTemplateItem[]
  instances      ClosingChecklist[]

  @@index([organizationId])
  @@map("closing_checklist_templates")
}

model ClosingChecklistTemplateItem {
  id                     String                   @id @default(cuid())
  organizationId         String
  templateId             String
  category               ChecklistItemCategory
  label                  String
  description            String?
  required               Boolean                  @default(true)
  completionEvidenceType CompletionEvidenceType   @default(MANUAL)
  position               Int
  createdAt              DateTime                 @default(now())
  template               ClosingChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([templateId])
  @@map("closing_checklist_template_items")
}

// The instantiated, per-Opportunity checklist (CC-A, 1:1 with an Opportunity). It records
// the template + version it was snapshotted from (CC-10) and is thereafter independent.
model ClosingChecklist {
  id               String                    @id @default(cuid())
  organizationId   String
  opportunityId    String                    @unique
  sourceTemplateId String?
  templateVersion  Int?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  organization     Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity      Opportunity               @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  sourceTemplate   ClosingChecklistTemplate? @relation(fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  items            ClosingChecklistItem[]

  @@index([organizationId])
  @@map("closing_checklists")
}

// One required-business-state item on an instantiated checklist (CC-A/CC-B). Operational
// and mutable; every state change is audited. Owner/completedBy/waivedBy and evidence
// references are plain scalars (no FK) — mirrors the codebase idiom for cross-domain ids.
model ClosingChecklistItem {
  id                     String                 @id @default(cuid())
  organizationId         String
  checklistId            String
  category               ChecklistItemCategory
  label                  String
  description            String?
  required               Boolean                @default(true)
  completionEvidenceType CompletionEvidenceType @default(MANUAL)
  position               Int
  status                 ChecklistItemStatus    @default(PENDING)
  ownerId                String?
  dueDate                DateTime?
  completedById          String?
  completedAt            DateTime?
  waivedById             String?
  waivedAt               DateTime?
  waiverReason           String?
  evidenceDocumentId     String?
  evidenceTaskId         String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  checklist              ClosingChecklist       @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([checklistId])
  @@map("closing_checklist_items")
}

// Closing Center Slice 2 — Escrow (EC-A). A first-class financial record, 1:1 with an
// Opportunity, org-scoped and cascade-owned. Holds MUTABLE operational escrow state through
// the NOT_OPENED→OPENED→DEPOSITED lifecycle (EC-B). On a terminal transition an immutable
// EscrowEvent snapshot is written (EC-I) and the service freezes this record (EC-11).
// Money is whole-USD Int (EC-C); holder is free-text (EC-D); proof is a scalar Document id
// (EC-F). Escrow never touches the underwriting engine (EC-1/EC-9/EC-10).
model EscrowRecord {
  id                       String        @id @default(cuid())
  organizationId           String
  opportunityId            String        @unique
  status                   EscrowStatus  @default(NOT_OPENED)
  earnestAmountUsd         Int?
  escrowHolderName         String?
  escrowHolderContact      String?
  openedDate               DateTime?
  earnestDueDate           DateTime?
  depositedDate            DateTime?
  contingencyDeadline      DateTime?
  proofOfDepositDocumentId String?
  // Milestone attribution (who/when), mirroring the closing-item stamp pattern.
  openedById               String?
  openedAt                 DateTime?
  depositedById            String?
  depositedAt              DateTime?
  resolvedById             String?
  resolvedAt               DateTime?
  resolutionReason         String?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  organization             Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity              Opportunity   @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  events                   EscrowEvent[]

  @@index([organizationId])
  @@map("escrow_records")
}

// The immutable, append-only historical fact of a TERMINAL escrow outcome (EC-I/EC-11).
// It SNAPSHOTS the amount/holder/proof/actor/timestamp at resolution so later edits to the
// mutable EscrowRecord can never rewrite what happened. Never updated or deleted.
model EscrowEvent {
  id                      String          @id @default(cuid())
  organizationId          String
  escrowRecordId          String
  type                    EscrowEventType
  amountUsdSnapshot       Int?
  holderNameSnapshot      String?
  proofDocumentIdSnapshot String?
  actorId                 String?
  reason                  String?
  occurredAt              DateTime        @default(now())
  organization            Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  escrowRecord            EscrowRecord    @relation(fields: [escrowRecordId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([escrowRecordId])
  @@map("escrow_events")
}

// Closing Center Slice 3 — Financing (FC-A). A first-class OPERATIONAL record, 1:1 with an
// Opportunity, org-scoped and cascade-owned. Tracks the lender's process through the
// NOT_STARTED→APPLIED→COMMITTED→CLEARED→FUNDED (| DENIED | WITHDRAWN) lifecycle (FC-B) plus
// independently-recorded milestone dates. It owns NO loan economics — loan amount / DSCR /
// LTV/LTC / amortization stay underwriting-owned (FC-0/FC-3/FC-13); this record only
// REFERENCES underwriting output read-only at render time, never persisting it. On a terminal
// transition the service captures the FC-J snapshot (below) and FREEZES the record. Money is
// deliberately absent (FC-C/FC-5); lender is free-text (FC-D); documents are scalar ids (FC-E).
model FinancingRecord {
  id                                     String          @id @default(cuid())
  organizationId                         String
  opportunityId                          String          @unique
  status                                 FinancingStatus @default(NOT_STARTED)
  lenderName                             String?
  lenderContact                          String?
  // Independently-recorded milestone dates (FC-B) — the history (no event ledger, FC-I).
  applicationSubmittedDate               DateTime?
  appraisalOrderedDate                   DateTime?
  appraisalCompletedDate                 DateTime?
  commitmentReceivedDate                 DateTime?
  conditionsReceivedDate                 DateTime?
  conditionsSatisfiedDate                DateTime?
  closingPackageReceivedDate             DateTime?
  fundedDate                             DateTime?
  // Owned documents (FC-E) — scalar ids, no FK. Commitment letter + appraisal only this slice.
  commitmentLetterDocumentId             String?
  appraisalDocumentId                    String?
  // FC-J terminal snapshot — captured inside the record before it freezes, so a terminal
  // outcome is a durable historical fact without a separate event table (FC-I/FC-J).
  resolvedById                           String?
  resolvedAt                             DateTime?
  resolutionReason                       String?
  resolutionLenderNameSnapshot           String?
  resolutionCommitmentDocumentIdSnapshot String?
  resolutionAppraisalDocumentIdSnapshot  String?
  createdAt                              DateTime        @default(now())
  updatedAt                              DateTime        @updatedAt
  organization                           Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity                            Opportunity     @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("financing_records")
}

// The wholesale assignment lifecycle (v1.4 Slice 4, AS-B). Human operational workflow —
// never part of the underwriting engine (AS-1). Terminal states freeze the record (AS-4).
enum AssignmentStatus {
  NOT_STARTED
  DRAFTED
  EXECUTED
  CANCELLED
}

// The core wholesale transaction record (v1.4 Slice 4, AS-A): 1:1 with an Opportunity,
// carrying the assignor/assignee parties (AS-C, scalar-id-no-FK + free-text), the lifecycle,
// and an immutable execution snapshot (AS-D/AS-H). The assignment FEE's single source of
// truth stays on Opportunity.assignmentFeeUsd (AS-3) — this record only snapshots it at
// execution. The generated agreement lives in Document (ASSIGNMENT_AGREEMENT, AS-E), not here.
model AssignmentRecord {
  id                                  String           @id @default(cuid())
  organizationId                      String
  opportunityId                       String           @unique
  status                              AssignmentStatus @default(NOT_STARTED)
  // Parties (AS-C) — optional scalar references to existing Seller/Buyer rows (no FK, house
  // idiom) with free-text fallback for off-system parties. No Party entity (AS-11).
  assignorSellerId                    String?
  assignorName                        String?
  assignorContact                     String?
  assigneeBuyerId                     String?
  assigneeName                        String?
  assigneeContact                     String?
  // Terminal resolution (AS-H, FC-J pattern) — set on EXECUTED or CANCELLED; freezes the record.
  resolvedById                        String?
  resolvedAt                          DateTime?
  resolutionReason                    String?
  // Execution snapshot (AS-D/AS-H) — captured only on EXECUTED, an immutable historical fact.
  executedFeeUsdSnapshot              Int?
  executedContractValueUsdSnapshot    Int?
  executedAssignorNameSnapshot        String?
  executedAssigneeNameSnapshot        String?
  executedAgreementDocumentIdSnapshot String?
  createdAt                           DateTime         @default(now())
  updatedAt                           DateTime         @updatedAt
  organization                        Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity                         Opportunity      @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("assignment_records")
}

model BuyerMatch {
  id             String       @id @default(cuid())
  organizationId String
  opportunityId  String
  buyerId        String
  status         MatchStatus  @default(NEW)
  score          Int?
  thesis         String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity    Opportunity  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  buyer          Buyer        @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, buyerId])
  @@index([organizationId])
  @@index([buyerId])
  @@map("buyer_matches")
}

model Invitation {
  id             String           @id @default(cuid())
  organizationId String
  email          String // normalized lowercase
  role           UserRole
  tokenHash      String           @unique // HMAC of the raw token; raw is never stored
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  invitedById    String? // audit-only plain column (no FK)
  acceptedUserId String? // audit-only plain column (no FK)
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitations")
}

model ActivityLog {
  id                    String       @id @default(cuid())
  organizationId        String
  opportunityId         String?
  propertyId            String?
  sellerId              String?
  buyerId               String?
  actorId               String?
  // v2.0.1 (additive) — explicit authorship without overloading the User FK.
  // Every existing row and every human write defaults to USER: zero behavior change.
  // automationExecutionId is a scalar (history-safe, no FK) linking an automation-emitted
  // row to the AutomationExecution that produced it; actorId stays null for automation.
  actorType             ActorType    @default(USER)
  automationExecutionId String?
  eventType             String
  eventLabel            String
  eventBody             String?
  createdAt             DateTime     @default(now())
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity           Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  property              Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  seller                Seller?      @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  buyer                 Buyer?       @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  actor                 User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("activity_log")
}

// ── Automation domain (Version 2.0, Phase 2.0.1) ─────────────────────────────
// The Automation spine: a bounded orchestration domain that reads projections,
// evaluates policy, and records its own execution — it never owns authoritative
// business state (AU-1). AutomationJob = mutable lifecycle / queue row;
// AutomationExecution = immutable, insert-only attempt ledger (A8/AU-8).
// Design authority: AUTOMATION_ARCHITECTURE_LOCK.md + VERSION_2_0_PHASE_2_0_1_*.

// Job lifecycle (mutable, on AutomationJob). Terminal: SUCCEEDED, DEAD_LETTERED,
// CANCELLED, SUPERSEDED. FAILED is deliberately NOT here — a failed *attempt* is an
// AutomationExecution outcome; a job that can no longer succeed ends DEAD_LETTERED.
enum AutomationJobStatus {
  PENDING
  QUEUED
  RUNNING
  RETRY_SCHEDULED
  SUCCEEDED
  DEAD_LETTERED
  CANCELLED
  SUPERSEDED
}

// Immutable per-attempt outcome (on AutomationExecution). Mirrors the RefreshJob
// terminal trio (SUCCEEDED / NOOP / FAILED).
enum AutomationExecutionOutcome {
  SUCCEEDED
  NOOP
  FAILED
}

// Why a job ran. 2.0.1 uses SCHEDULE; DOMAIN_EVENT/WEBHOOK/MANUAL are reserved for
// later phases (event-driven transactional outbox, external callbacks, operator runs).
enum AutomationTriggerType {
  SCHEDULE
  DOMAIN_EVENT
  WEBHOOK
  MANUAL
}

// Structured policy decision (no such enum existed in the codebase before 2.0.1).
// REQUIRE_APPROVAL is reserved — the 2.0.1 read-only proof job never uses it.
enum AutomationPolicyDecision {
  ALLOW
  DENY
  REQUIRE_APPROVAL
  NO_ACTION
  STALE_CONTEXT
}

// Failure taxonomy (expands the email outbox's binary `permanent` flag). Retry/alert/
// dead-letter behavior per class is defined in the Implementation Plan §9.
enum AutomationFailureClass {
  TRANSIENT_INFRASTRUCTURE
  DATABASE_CONTENTION
  DEPENDENCY_UNAVAILABLE
  POLICY_DENIED
  STALE_CONTEXT
  VALIDATION_FAILURE
  PERMISSION_FAILURE
  ORG_SCOPE_VIOLATION
  INVARIANT_VIOLATION
  UNKNOWN
}

// The principal that performed the work. AUTOMATION never impersonates a user (AU-3).
enum AutomationPrincipalType {
  AUTOMATION
  SYSTEM
  WEBHOOK
}

// Discriminates ActivityLog authorship without overloading the User FK. Existing rows
// and all human writes default to USER — no behavior change.
enum ActorType {
  USER
  SYSTEM
  AUTOMATION
  WEBHOOK
}

// The durable unit of automation intent and its mutable lifecycle. Also the queue row:
// the executor claims due jobs with SELECT ... FOR UPDATE SKIP LOCKED. Idempotency anchor
// is the compound unique below (RefreshJob precedent, extended). This row is UPDATED as it
// moves through its lifecycle; the immutable audit lives in AutomationExecution.
model AutomationJob {
  id             String                @id @default(cuid())
  organizationId String
  automationType String
  status         AutomationJobStatus   @default(PENDING)
  triggerType    AutomationTriggerType @default(SCHEDULE)

  // Idempotency scope (Determination 4)
  sourceType    String
  sourceId      String // scalar, NOT an FK (history-safe; may be cross-domain)
  policyKey     String
  policyVersion Int
  occurrenceKey String // deterministic bucket (e.g. "2026-07-16T14" per target)

  // Scheduling / retry
  attempts       Int       @default(0)
  maxAttempts    Int       @default(5)
  availableAt    DateTime  @default(now())
  nextAttemptAt  DateTime?
  leaseExpiresAt DateTime?
  runningAttempt Int?

  // Bookkeeping
  correlationId    String?
  causationId      String?
  lastFailureClass AutomationFailureClass?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executions   AutomationExecution[]

  @@unique([organizationId, automationType, sourceType, sourceId, policyVersion, occurrenceKey], name: "automation_job_idempotency")
  @@index([status, availableAt])
  @@index([status, nextAttemptAt])
  @@index([status, leaseExpiresAt])
  @@index([organizationId, status])
  @@map("automation_jobs")
}

// One IMMUTABLE row per attempt (completed or abandoned). INSERT-ONLY — never updated,
// never deleted (AU-8). Written inside the same $transaction that finalizes the job's
// status. This is the operational ledger that complements (never replaces) ActivityLog.
model AutomationExecution {
  id              String @id @default(cuid())
  organizationId  String
  automationJobId String
  attemptNumber   Int

  automationType String
  triggerType    AutomationTriggerType
  triggerRef     String?

  policyKey          String
  policyVersion      Int
  policyDecision     AutomationPolicyDecision
  contextFingerprint String // SHA-256 of the canonicalized context (no raw body stored)

  startedAt  DateTime
  finishedAt DateTime
  durationMs Int

  outcome              AutomationExecutionOutcome
  producedDomainEffect Boolean                    @default(false) // ALWAYS false in 2.0.1
  retryAllowed         Boolean                    @default(false)
  failureClass         AutomationFailureClass?
  error                String?

  principalType    AutomationPrincipalType @default(AUTOMATION)
  principalKey     String
  approvedByUserId String? // reserved for future REQUIRE_APPROVAL commits (scalar)

  correlationId String?
  causationId   String?
  activityLogId String? // scalar; set only if the best-effort mirror succeeded

  createdAt DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job          AutomationJob @relation(fields: [automationJobId], references: [id], onDelete: Cascade)

  @@unique([automationJobId, attemptNumber], name: "automation_execution_attempt")
  @@index([organizationId, createdAt])
  @@index([organizationId, outcome])
  @@index([automationJobId])
  @@map("automation_executions")
}

// ── Opportunity Pipeline · Slice 2 · E1 Core Fact Infrastructure ─────────────────────────────
// An APPEND-ONLY authoritative fact ledger. A row is IMMUTABLE after creation — there is no update
// or delete path (Law 5 / GI-1). State changes are new rows linked via `supersedesFactId`
// (supersession = a LINK, never a mutation). This table stores business truth only; projection,
// authorization, policy evaluation, and inconsistency computation (E2–E4) CONSUME it and never
// modify it. See docs/architecture/E1_CORE_FACT_INFRASTRUCTURE_DESIGN.md.
model PipelineFact {
  id             String @id @default(cuid()) // Fact Record Identity (immutable ledger row)
  factChainId    String // Fact Semantic Identity — constant across a supersession chain
  globalSequence BigInt @default(autoincrement()) // AUTHORITATIVE total order (timestamps are informational)

  organizationId String
  opportunityId  String

  factType   String            // Spec-defined ontology; validated by the code-side registry
  factClass  PipelineFactClass // ARTIFACT | EVIDENCE | DECISION (GI-3)
  subjectKey String?           // collection-fact scope (per item/contingency/checklist); null = singleton
  state      String?           // e.g. OPENED/RELEASED/FUNDED (facts have states — 5A-INV-2)
  payload    Json?             // typed per factType (registry-validated): funds{recipient,purpose,amount,obligation}, evidence refs, exception scope

  policyVersion   String? // version-anchoring (STM-INV-7)
  ruleSetVersion  String? //   GI-2 reproducibility
  artifactVersion String? //   LOI/contract version (3.1/4.1-INV-1)

  operation        PipelineFactOperation // DRAFT|RECORD_EVIDENCE|DECLARE|RETRACT|CORRECT|INVALIDATE|ACCEPT_EXCEPTION
  supersedesFactId String? // append-only supersession LINK (never a mutation) — GI-1
  supersedesFact   PipelineFact?  @relation("PipelineFactSupersession", fields: [supersedesFactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supersededBy     PipelineFact[] @relation("PipelineFactSupersession")

  actorType  PipelineActorType      // HUMAN|EXTERNAL_PRINCIPAL|DETERMINISTIC_EVALUATOR|MIGRATION_PRINCIPAL
  actorId    String? // user/seam/evaluator/migration identity
  provenance PipelineFactProvenance @default(VERIFIED) // VERIFIED | MIGRATION_ORIGIN (STM §9c, AUTH-INV-9)
  reason     String? // required for RETRACT/REOPEN/CORRECT/ACCEPT_EXCEPTION (code-enforced)

  occurredAt DateTime? // business event time (informational)
  recordedAt DateTime  @default(now()) // when recorded (immutable; no @updatedAt)

  @@index([organizationId, opportunityId, factType, subjectKey], map: "pipeline_facts_org_opp_type_subject_idx")
  @@index([factChainId], map: "pipeline_facts_chain_idx")
  @@index([supersedesFactId], map: "pipeline_facts_supersedes_idx")
  @@index([organizationId, opportunityId, globalSequence], map: "pipeline_facts_org_opp_seq_idx")
  @@map("pipeline_facts")
}

enum PipelineFactClass {
  ARTIFACT
  EVIDENCE
  DECISION
}

enum PipelineFactOperation {
  DRAFT
  RECORD_EVIDENCE
  DECLARE
  RETRACT
  CORRECT
  INVALIDATE
  ACCEPT_EXCEPTION
}

enum PipelineActorType {
  HUMAN
  EXTERNAL_PRINCIPAL
  DETERMINISTIC_EVALUATOR
  MIGRATION_PRINCIPAL
}

enum PipelineFactProvenance {
  VERIFIED
  MIGRATION_ORIGIN
}

/// E6 API transport idempotency (operational metadata — NOT part of the semantic fact model). One record per
/// (organizationId, requestId), written atomically with the committed fact; a retry replays `originalResponse`.
model ApiIdempotencyRecord {
  id               String   @id @default(cuid())
  organizationId   String
  requestId        String
  requestDigest    String
  factId           String?
  decisionId       String
  originalResponse Json
  responseDigest   String
  createdAt        DateTime @default(now())

  @@unique([organizationId, requestId], map: "api_idempotency_org_request_key")
  @@map("api_idempotency_records")
}
