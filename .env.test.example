# Local test database for the E2E suite. Copy this file to .env.test (gitignored)
# and fill in the real password. The database name MUST end in "_test" — the
# e2e-guard refuses to run against anything else, so production is never a target.
#
# One-time creation (privileged role, run manually):
#   sudo -u postgres createdb -O commercial_app commercial_crowdexpanse_test
# Then: npm run test:db:setup

DATABASE_URL="postgresql://commercial_app:REPLACE_WITH_PASSWORD@127.0.0.1:5432/commercial_crowdexpanse_test"
SESSION_SECRET="test-dummy-secret-not-used-in-production"
UPLOAD_DIR="/tmp/commercial-test-uploads"
